{
  "manifest_version": 3,
  "name": "AI Summary",
  "version": "1.1",
  "description": "Summarize any page or YouTube video with your choice of AI model — streaming, saved, and searchable.",
  "permissions": ["activeTab", "scripting", "storage", "unlimitedStorage", "nativeMessaging"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "AI Summary — open panel / history"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/marked.min.js", "lib/dompurify.min.js", "content-dual.js"]
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["lib/marked.min.js", "lib/dompurify.min.js", "youtube-content.js"]
    }
  ],
  "options_page": "options.html"
}
