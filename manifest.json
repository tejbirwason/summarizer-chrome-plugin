{
  "manifest_version": 3,
  "name": "AI Summary & Draft",
  "version": "1.0",
  "description": "Two floating emoji buttons: Summarize with o3 & Draft responses with Claude",
  "permissions": ["activeTab", "scripting", "storage", "nativeMessaging"],
  "host_permissions": ["https://api.anthropic.com/*", "https://api.openai.com/*", "http://135.181.106.49/*", "<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["lib/marked.min.js", "lib/dompurify.min.js", "content-dual.js"]
    },
    {
      "matches": ["*://*.youtube.com/*"],
      "js": ["lib/marked.min.js", "lib/dompurify.min.js", "youtube-content.js"]
    }
  ],
  "options_page": "options.html"
}
