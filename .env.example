# API Key for authenticating requests from Chrome extension
API_KEY=your-secret-api-key-here

# OpenRouter API Key — every model in ai-config.json's "models" array routes through
# OpenRouter (litellm_model is prefixed "openrouter/"), so this is the only key
# in-window summarization needs.
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-key-here

# Anthropic API Key — only needed if you add a direct "anthropic/..." model back to
# ai-config.json. Response drafting reads its Claude key from config.js, not here.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Webshare Proxy Credentials (for YouTube transcript fetching)
WEBSHARE_PROXY_USERNAME=your-webshare-username
WEBSHARE_PROXY_PASSWORD=your-webshare-password
