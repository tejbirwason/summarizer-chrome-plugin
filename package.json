  "bugs": {
    "url": "https://github.com/tejbirwason/summarizer-chrome-plugin/issues"
  },
  "homepage": "https://github.com/tejbirwason/summarizer-chrome-plugin#readme",
  "devDependencies": {
    "@types/chrome": "^0.0.326",
    "jest": "^30.0.0",
    "jest-environment-jsdom": "^30.0.0",
    "node-fetch": "^2.7.0",
    "puppeteer": "^24.26.1"
  }
